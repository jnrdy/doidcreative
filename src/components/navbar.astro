---
---

<nav
  id="navbar"
  class="fixed top-0 left-0 w-full z-50 transition-all duration-500"
>
  <div
    id="nav-inner"
    class="flex items-center justify-between px-8 md:px-16 py-6 transition-all duration-500"
  >
    <!-- LOGO -->
    <img
      id="nav-logo"
      src="/images/new/logo-white.png"
      alt="DO.ID Logo"
      class="h-8 md:h-10 object-contain transition-all duration-300 opacity-100"
    />

    <!-- MENU -->
    <div class="hidden md:flex items-center gap-10">
      <button data-target="home" class="nav-link">HOME</button>
      <button data-target="expertise" class="nav-link">EXPERTISE</button>
      <button data-target="paradigm" class="nav-link">PARADIGM</button>
      <button data-target="services" class="nav-link">SERVICES</button>
    </div>

    <!-- CTA -->
    <button
      id="nav-btn"
      class="border px-5 py-2.5 text-xs md:text-sm rounded-full transition-all duration-300"
    >
      LET'S TALK
    </button>
  </div>
</nav>

<script>
  const inner = document.getElementById("nav-inner");
  const btn = document.getElementById("nav-btn");
  const logo = document.getElementById("nav-logo");
  const links = document.querySelectorAll(".nav-link");

  // =========================
  // LOGO FADE
  // =========================
  const fadeLogo = (newSrc) => {
    if (logo.src.includes(newSrc)) return;

    logo.style.opacity = 0;

    setTimeout(() => {
      logo.src = newSrc;
      logo.style.opacity = 1;
    }, 150);
  };

  // =========================
  // STATE LIGHT
  // =========================
  const setLight = () => {
    btn.className =
      "border border-white text-white px-5 py-2.5 text-xs md:text-sm rounded-full transition-all duration-300 hover:bg-white hover:text-[#443E7F]";

    links.forEach((link) => {
      link.className =
        "nav-link text-white text-sm tracking-wide font-medium transition-all duration-300 hover:opacity-70 hover:scale-105 active:scale-95";
    });

    fadeLogo("/images/logo-white.png");
  };

  // =========================
  // STATE DARK
  // =========================
  const setDark = () => {
    btn.className =
      "border border-[#443E7F] text-[#443E7F] px-5 py-2.5 text-xs md:text-sm rounded-full transition-all duration-300 hover:bg-[#443E7F] hover:text-white";

    links.forEach((link) => {
      link.className =
        "nav-link text-[#443E7F] text-sm tracking-wide font-medium transition-all duration-300 hover:opacity-70 hover:scale-105 active:scale-95";
    });

    fadeLogo("/images/logo-black.png");
  };

  // =========================
  // NAVBAR SHRINK
  // =========================
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      inner.classList.add(
        "py-3",
        "backdrop-blur-md",
        "bg-white/10",
        "shadow-lg"
      );
      inner.classList.remove("py-6");
    } else {
      inner.classList.remove(
        "py-3",
        "backdrop-blur-md",
        "bg-white/10",
        "shadow-lg"
      );
      inner.classList.add("py-6");
    }
  });

  // =========================
  // SECTION COLOR DETECTION
  // =========================
  const sections = document.querySelectorAll("[data-nav]");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const mode = entry.target.getAttribute("data-nav");

          if (mode === "light") setLight();
          if (mode === "dark") setDark();
        }
      });
    },
    {
      root: null,
      rootMargin: "-40% 0px -40% 0px",
      threshold: 0,
    }
  );

  sections.forEach((section) => observer.observe(section));

  // =========================
  // INIT
  // =========================
  setLight();

  // =========================
  // NAV MENU SCROLL
  // =========================
  const navLinks = document.querySelectorAll(".nav-link");

  navLinks.forEach((link) => {
    link.addEventListener("click", () => {
      const targetId = link.getAttribute("data-target");
      const target = document.getElementById(targetId);

      if (!target) return;

      const yOffset = -80;
      const y =
        target.getBoundingClientRect().top +
        window.pageYOffset +
        yOffset;

      window.scrollTo({
        top: y,
        behavior: "smooth",
      });
    });
  });

  // =========================
  // CTA SCROLL TO FOOTER
  // =========================
  const navBtn = document.getElementById("nav-btn");
  const footer = document.getElementById("footer");

  if (navBtn && footer) {
    navBtn.addEventListener("click", () => {
      navBtn.classList.add("scale-95");

      setTimeout(() => {
        navBtn.classList.remove("scale-95");
      }, 120);

      footer.scrollIntoView({
        behavior: "smooth",
        block: "start",
      });
    });
  }
</script>