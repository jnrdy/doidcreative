---

---

<nav
  id="navbar"
  class="fixed top-0 left-0 w-full z-50 transition-all duration-500"
>
  <div
    id="nav-inner"
    class="flex items-center justify-between px-6 md:px-16 py-6 transition-all duration-500"
  >
    <!-- LOGO -->
    <img
      id="nav-logo"
      src="/images/new/logo-white.png"
      alt="DO.ID Logo"
      class="h-8 md:h-10 object-contain transition-all duration-300 opacity-100"
    />

    <!-- DESKTOP MENU -->
    <div class="hidden md:flex items-center gap-10">
      <button data-target="home" class="nav-link">HOME</button>
      <button data-target="expertise" class="nav-link">EXPERTISE</button>
      <button data-target="paradigm" class="nav-link">PARADIGM</button>
      <button data-target="services" class="nav-link">SERVICES</button>
    </div>

    <!-- HAMBURGER (MOBILE) -->
    <button id="menu-toggle" class="md:hidden relative w-6 h-6 z-50">
      <span class="line top"></span>
      <span class="line middle"></span>
      <span class="line bottom"></span>
    </button>

    <!-- CTA (DESKTOP ONLY) -->
    <button
      id="nav-btn"
      class="hidden md:block border px-5 py-2.5 text-xs md:text-sm rounded-full transition-all duration-300"
    >
      LET'S TALK
    </button>
  </div>
</nav>

<!-- MOBILE MENU -->
<div
  id="mobile-menu"
  class="fixed inset-0 bg-[#443E7F] z-40 flex flex-col items-center justify-center gap-10
  opacity-0 pointer-events-none transition-all duration-500"
>
  <button
    data-target="home"
    class="mobile-link text-white text-2xl font-semibold tracking-wide"
    >HOME</button
  >
  <button
    data-target="expertise"
    class="mobile-link text-white text-2xl font-semibold tracking-wide"
    >EXPERTISE</button
  >
  <button
    data-target="paradigm"
    class="mobile-link text-white text-2xl font-semibold tracking-wide"
    >PARADIGM</button
  >
  <button
    data-target="services"
    class="mobile-link text-white text-2xl font-semibold tracking-wide"
    >SERVICES</button
  >

  <button
    id="mobile-cta"
    class="mt-10 border border-white text-white px-6 py-3 rounded-full"
  >
    LET'S TALK
  </button>
</div>

<script>
  const inner = document.getElementById("nav-inner");
  const btn = document.getElementById("nav-btn");
  const logo = document.getElementById("nav-logo");
  const links = document.querySelectorAll(".nav-link");
  const hamburgerLines = document.querySelectorAll("#menu-toggle span");

  // =========================
  // LOGO FADE
  // =========================
  const fadeLogo = (newSrc) => {
    if (logo.src.includes(newSrc)) return;

    logo.style.opacity = 0;

    setTimeout(() => {
      logo.src = newSrc;
      logo.style.opacity = 1;
    }, 150);
  };

  // =========================
  // STATE LIGHT
  // =========================
  const setLight = () => {
    if (btn) {
      btn.className =
        "hidden md:block border border-white text-white px-5 py-2.5 text-xs md:text-sm rounded-full transition-all duration-300 hover:bg-white hover:text-[#443E7F]";
    }

    links.forEach((link) => {
      link.className =
        "nav-link text-white text-sm tracking-wide font-medium transition-all duration-300 hover:opacity-70 hover:scale-105 active:scale-95";
    });

    // HAMBURGER COLOR (LIGHT)
    hamburgerLines.forEach((line) => {
      line.style.backgroundColor = "white";
    });

    fadeLogo("/images/logo-white.png");
  };

  // =========================
  // STATE DARK
  // =========================
  const setDark = () => {
    if (btn) {
      btn.className =
        "hidden md:block border border-[#443E7F] text-[#443E7F] px-5 py-2.5 text-xs md:text-sm rounded-full transition-all duration-300 hover:bg-[#443E7F] hover:text-white";
    }

    links.forEach((link) => {
      link.className =
        "nav-link text-[#443E7F] text-sm tracking-wide font-medium transition-all duration-300 hover:opacity-70 hover:scale-105 active:scale-95";
    });

    // HAMBURGER COLOR (DARK)
    hamburgerLines.forEach((line) => {
      line.style.backgroundColor = "#443E7F";
    });

    fadeLogo("/images/logo-black.png");
  };

  // =========================
  // NAVBAR SHRINK
  // =========================
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      inner.classList.add(
        "py-3",
        "backdrop-blur-md",
        "bg-white/10",
        "shadow-lg",
      );
      inner.classList.remove("py-6");
    } else {
      inner.classList.remove(
        "py-3",
        "backdrop-blur-md",
        "bg-white/10",
        "shadow-lg",
      );
      inner.classList.add("py-6");
    }
  });

  // =========================
  // SECTION COLOR DETECTION
  // =========================
  const sections = document.querySelectorAll("[data-nav]");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const mode = entry.target.getAttribute("data-nav");

          if (mode === "light") setLight();
          if (mode === "dark") setDark();
        }
      });
    },
    {
      root: null,
      rootMargin: "-40% 0px -40% 0px",
      threshold: 0,
    },
  );

  sections.forEach((section) => observer.observe(section));

  // =========================
  // INIT
  // =========================
  setLight();

  // =========================
  // DESKTOP NAV SCROLL
  // =========================
  const navLinks = document.querySelectorAll(".nav-link");

  navLinks.forEach((link) => {
    link.addEventListener("click", () => {
      const targetId = link.getAttribute("data-target");
      const target = document.getElementById(targetId);

      if (!target) return;

      target.scrollIntoView({
        behavior: "smooth",
        block: "start",
      });
    });
  });

  // =========================
  // MOBILE MENU TOGGLE + ANIMATION
  // =========================
  const toggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");

  toggle.addEventListener("click", () => {
    mobileMenu.classList.toggle("opacity-0");
    mobileMenu.classList.toggle("pointer-events-none");

    toggle.classList.toggle("menu-open"); // <-- animasi X
  });

  // =========================
  // MOBILE LINK SCROLL + CLOSE
  // =========================
  const mobileLinks = document.querySelectorAll(".mobile-link");

  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      const targetId = link.getAttribute("data-target");
      const target = document.getElementById(targetId);

      mobileMenu.classList.add("opacity-0", "pointer-events-none");
      toggle.classList.remove("menu-open"); // <-- balik ke hamburger

      if (!target) return;

      target.scrollIntoView({
        behavior: "smooth",
        block: "start",
      });
    });
  });

  // =========================
  // CTA SCROLL (DESKTOP + MOBILE)
  // =========================
  const footer = document.getElementById("footer");
  const mobileCta = document.getElementById("mobile-cta");

  if (btn && footer) {
    btn.addEventListener("click", () => {
      btn.classList.add("scale-95");

      setTimeout(() => {
        btn.classList.remove("scale-95");
      }, 120);

      footer.scrollIntoView({
        behavior: "smooth",
        block: "start",
      });
    });
  }

  if (mobileCta && footer) {
    mobileCta.addEventListener("click", () => {
      mobileMenu.classList.add("opacity-0", "pointer-events-none");
      toggle.classList.remove("menu-open");

      footer.scrollIntoView({
        behavior: "smooth",
        block: "start",
      });
    });
  }
</script>
