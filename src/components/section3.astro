<section data-nav="dark" class="w-full bg-white py-20 md:py-24">
  <div class="max-w-7xl mx-auto px-6 md:px-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 items-center">
      <!-- LEFT: IMAGE -->
      <div
        data-animate
        class="w-full opacity-0 scale-95 transition-all duration-700"
      >
        <img
          src="/images/logo.png"
          alt="DO.ID Visual"
          class="w-full h-auto rounded-2xl object-cover shadow-2xl"
        />
      </div>

      <!-- RIGHT: CONTENT -->
      <div class="flex flex-col gap-12">
        <!-- ITEM 1 -->
        <div
          data-animate
          class="flex gap-5 opacity-0 translate-x-10 transition-all duration-700 delay-150"
        >
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 bg-[#FD8181] rounded-full"></div>
            <div class="w-[2px] h-full bg-[#FD8181] mt-2"></div>
          </div>

          <div>
            <h3 class="text-black font-semibold text-xl md:text-2xl mb-3">
              Marketing Strategy
            </h3>
            <p class="text-black text-base md:text-lg leading-relaxed">
              Visual diambil dari grafik naik yang biasa dijadikan visualisasi
              untuk grafik yang meningkat. Visual panah naik bisa dilihat pada
              negative space yang ada di huruf D.
            </p>
          </div>
        </div>

        <!-- ITEM 2 -->
        <div
          data-animate
          class="flex gap-5 opacity-0 translate-x-10 transition-all duration-700 delay-300"
        >
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 bg-[#FDC564] rounded-full"></div>
            <div class="w-[2px] h-full bg-[#FDC564] mt-2"></div>
          </div>

          <div>
            <h3 class="text-black font-semibold text-xl md:text-2xl mb-3">
              Event Organizer
            </h3>
            <p class="text-black text-base md:text-lg leading-relaxed">
              Visual merepresentasikan tanda ceklis yang digunakan untuk
              menandakan sebuah item atau tugas telah siap. Visual tanda centang
              bisa dilihat pada negative space yang ada di huruf O.
            </p>
          </div>
        </div>

        <!-- ITEM 3 -->
        <div
          data-animate
          class="flex gap-5 opacity-0 translate-x-10 transition-all duration-700 delay-450"
        >
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 bg-[#443E7F] rounded-full"></div>
            <div class="w-[2px] h-full bg-[#443E7F] mt-2"></div>
          </div>

          <div>
            <h3 class="text-black font-semibold text-xl md:text-2xl mb-3">
              Branding
            </h3>
            <p class="text-black text-base md:text-lg leading-relaxed">
              Visual merepresentasikan label brand yang terkelupas. Bagian putih
              pada huruf D ini menandakan label yang sedang dibuka.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove(
            "opacity-0",
            "translate-y-10",
            "translate-x-10",
            "scale-95",
          );

          entry.target.classList.add(
            "opacity-100",
            "translate-y-0",
            "translate-x-0",
            "scale-100",
          );
        }
      });
    },
    { threshold: 0.2 },
  );

  document.querySelectorAll("[data-animate]").forEach((el) => {
    observer.observe(el);
  });
</script>
