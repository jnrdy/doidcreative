---
import "../styles/global.css";
import Navbar from "../components/navbar.astro";
import Hero from "../components/hero.astro";
import Section2 from "../components/section2.astro";
import Section3 from "../components/section3.astro";
import Beyond from "../components/beyondtheproject-section4.astro";
import Paradigm from "../components/paradigm-section5.astro";
import Interventions from "../components/interventions-section6.astro";
import ServicesLineup from "../components/servicesLineup-section7.astro";
import Divider from "../components/divider.astro";
import Footer from "../components/footer.astro";
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>DO.ID Creative — Cognitive & Sensory Marketing Agency</title>

  <meta
    name="description"
    content="DO.ID Creative is a marketing agency specializing in cognitive storytelling, experiential branding, and measurable business impact."
  />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.ico" />

  <!-- Open Graph -->
  <meta property="og:title" content="DO.ID Creative" />
  <meta
    property="og:description"
    content="Engineering cognitive storytelling and behavioral resonance."
  />
  <meta property="og:image" content="/images/logo.png" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://doidcreative.com" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="DO.ID Creative" />
  <meta
    name="twitter:description"
    content="Engineering cognitive storytelling and behavioral resonance."
  />
  <meta name="twitter:image" content="/images/logo.png" />
</head>
<Navbar />
<Hero />
<Section2 />
<Section3 />
<Beyond />
<Paradigm />
<Interventions />
<ServicesLineup />
<Divider />
<Footer />
